# Copy to .env for local (non-Docker) runs, or set these as real environment
# variables / Compose env entries. Never commit a file with real values filled in.

# "openai" calls the real OpenAI API and requires OPENAI_API_KEY below.
# "fake" (the default) returns deterministic canned responses - no key needed,
# used for local development and CI.
AI_PROVIDER=fake

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
COMPLETION_MODEL=gpt-4o-mini

# Must match AI_SERVICE_SHARED_SECRET on the PHP app side - checked on every
# request except /health.
SHARED_SECRET=

REQUEST_TIMEOUT_SECONDS=20
MAX_RETRIES=2
