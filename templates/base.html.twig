<!DOCTYPE html>
<html class="bg-zinc-950">
    <head>
        <meta charset="UTF-8">
        <meta name="color-scheme" content="dark">
        <title>{% block title %}Chuck Norris Jokes Hub{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        {% block importmap %}{{ importmap('app', { nonce: csp_nonce('script') }) }}{% endblock %}
    </head>
    <body class="min-h-dvh bg-zinc-950 text-zinc-100 antialiased font-sans">
            {% block header %}
                <div data-controller="nav-toggle">
                    <div class="sticky top-0 z-20 flex items-center justify-between bg-zinc-900 border-b border-zinc-800 px-4 py-3 lg:hidden">
                        <button
                                type="button"
                                data-action="nav-toggle#toggle"
                                aria-label="Toggle menu"
                                class="text-zinc-300 transition transition-all hover:text-zinc-100 focus:outline-none">
                            <svg class="h-7 w-7 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path
                                        data-nav-toggle-target="closeIcon"
                                        class="hidden"
                                        fill-rule="evenodd"
                                        clip-rule="evenodd"
                                        d="M18.278 16.864a1 1 0 0 1-1.414 1.414l-4.829-4.828-4.828 4.828a1 1 0 0 1-1.414-1.414l4.828-4.829-4.828-4.828a1 1 0 0 1 1.414-1.414l4.829 4.828 4.828-4.828a1 1 0 1 1 1.414 1.414l-4.828 4.829 4.828 4.828z"
                                />
                                <path
                                        data-nav-toggle-target="openIcon"
                                        fill-rule="evenodd"
                                        d="M4 5h16a1 1 0 0 1 0 2H4a1 1 0 1 1 0-2zm0 6h16a1 1 0 0 1 0 2H4a1 1 0 0 1 0-2zm0 6h16a1 1 0 0 1 0 2H4a1 1 0 0 1 0-2z"
                                />
                            </svg>
                        </button>

                        <a href="{{ path('app_homepage') }}" class="uppercase font-bold text-sm tracking-wide text-zinc-100">Chuckifier</a>

                        <span class="h-7 w-7"></span>
                    </div>

                    <div
                            data-nav-toggle-target="backdrop"
                            data-action="click->nav-toggle#close"
                            class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden">
                    </div>

                    <aside
                            data-nav-toggle-target="menu"
                            class="fixed inset-y-0 left-0 z-30 w-64 -translate-x-full transform bg-zinc-900 border-r border-zinc-800 transition-transform duration-200 ease-in-out lg:translate-x-0 lg:flex lg:flex-col">
                        <div class="hidden lg:flex items-center px-6 py-6 border-b border-zinc-800">
                            <a href="{{ path('app_homepage') }}" class="uppercase font-bold text-zinc-100 tracking-wide">Chuckifier</a>
                        </div>

                        <nav class="flex-1 overflow-y-auto px-3 py-6 space-y-1">
                            {% if app.user %}
                                <a
                                        href="{{ path('app_joke') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Jokes
                                </a>
                                <a
                                        href="{{ path('app_liked') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Liked
                                </a>
                                <a
                                        href="{{ path('app_top_jokes') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Top Jokes
                                </a>
                                <a
                                        href="{{ path('app_joke_of_the_day') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Joke of the Day
                                </a>
                                <a
                                        href="{{ path('app_joke_submit') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Submit
                                </a>
                                <a
                                        href="{{ path('app_joke_search') }}"
                                        data-action="nav-toggle#close"
                                        class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                        Search
                                </a>

                                <div class="mt-4 space-y-1 border-t border-zinc-800 pt-4">
                                    <a
                                            href="{{ path('app_profile') }}"
                                            data-action="nav-toggle#close"
                                            class="flex items-center gap-2 rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                            <img src="{{ app.user.avatarUrl }}" alt="" class="h-6 w-6 rounded-full">
                                            {{ app.user.displayName }}
                                    </a>
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a
                                                href="{{ path('app_admin_dashboard') }}"
                                                data-action="nav-toggle#close"
                                                class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                                Admin
                                        </a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </nav>

                        <div class="border-t border-zinc-800 p-3">
                            <a
                                    href="/{{ app.user ? 'logout' : 'login' }}"
                                    data-action="nav-toggle#close"
                                    class="block rounded px-4 py-2 uppercase text-xs font-bold tracking-wide text-zinc-300 no-underline hover:bg-zinc-800 hover:text-zinc-100">
                                    {{ app.user ? 'Chuckout' : 'Login' }}
                            </a>
                        </div>
                    </aside>
                </div>
            {% endblock %}

            <div class="{% block content_offset %}lg:pl-64{% endblock %}">
                {% for message in app.flashes('success') %}
                    <div class="w-4/5 md:w-2/5 m-auto text-center pt-8 text-green-400 font-light">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('verify_email_error') %}
                    <div class="w-4/5 md:w-2/5 m-auto text-center pt-8 text-red-400 font-light">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('comment_error') %}
                    <div class="w-4/5 md:w-2/5 m-auto text-center pt-8 text-red-400 font-light">{{ message }}</div>
                {% endfor %}

                {% if app.user and not app.user.isVerified %}
                    <div class="w-full bg-yellow-900/30 text-center py-3 text-sm text-yellow-200">
                        Please verify your email address.
                        <a href="{{ path('app_verify_email_resend') }}" class="underline font-bold">Resend verification email</a>
                    </div>
                {% endif %}

                {% block body %}{% endblock %}
            </div>

            {% block footer %}
                <footer class="border-t border-zinc-800 bg-zinc-900 fixed inset-x-0 bottom-0 lg:pl-64">
                    <p class="w-4/5 text-center py-4 m-auto text-sm text-zinc-400 font-light whitespace-nowrap">
                        Chuckifier © {{ "now"|date("Y") }} All Rights Reserved
                    </p>
                </footer>
            {% endblock %}
    </body>
</html>
