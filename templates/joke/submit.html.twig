{% extends 'base.html.twig' %}

{% block title %}Submit a joke{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto text-center">
        {% for message in app.flashes('success') %}
            <p class="text-center text-green-600 pt-6">{{ message }}</p>
        {% endfor %}

        <div class="py-12">
            <h1 class="uppercase font-bold text-5xl text-gray-800 pt-36 pb-8">
                Got a Chuck Norris joke?
            </h1>
            <span class="font-light text-gray-500 italic">
                Submit it below - it'll show up once an admin approves it.
            </span>

            {{ form_start(submissionForm) }}
                {{ form_row(submissionForm.joke, {'attr': {'class': 'bg-transparent block mt-10 mx-auto border-2 rounded sm:w-4/5 md:w-2/5 p-4 text-lg outline-none'}, 'label': false}) }}
                <div class="mt-6 sm:w-4/5 md:w-2/5 mx-auto text-left">
                    {{ form_label(submissionForm.category, null, {'label_attr': {'class': 'text-sm text-gray-500 uppercase font-bold'}}) }}
                    {{ form_widget(submissionForm.category, {'attr': {'class': 'block mt-2 border-2 rounded p-2 w-full'}}) }}
                </div>

                <button type="submit"
                        class="uppercase mt-10 font-bold border border-gray-300 bg-yellow-400 text-gray-800 text-lg py-4 px-12 rounded transition transition-all shadow-xl hover:border hover:border-gray-300 hover:bg-indigo-400 hover:text-zinc-100">
                    Submit joke
                </button>
            {{ form_end(submissionForm) }}
        </div>
    </div>
{% endblock %}
