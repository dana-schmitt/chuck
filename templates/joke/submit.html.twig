{% extends 'base.html.twig' %}

{% block title %}Submit a joke{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto text-center">
        {% for message in app.flashes('success') %}
            <p class="text-center text-green-400 pt-6">{{ message }}</p>
        {% endfor %}

        <div class="py-12">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-12 pb-8">
                Got a Chuck Norris joke?
            </h1>
            <span class="font-light text-zinc-400 italic">
                Submit it below - it'll show up once an admin approves it.
            </span>

            {{ form_start(submissionForm) }}
                {{ form_row(submissionForm.joke, {'attr': {'class': 'block mt-6 mx-auto w-full sm:w-4/5 md:w-2/5 rounded-md border border-zinc-700 bg-zinc-800 px-4 py-3 text-base text-zinc-100 placeholder-zinc-500 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}, 'label': false}) }}
                <div class="mt-4 sm:w-4/5 md:w-2/5 mx-auto text-left">
                    {{ form_label(submissionForm.category, null, {'label_attr': {'class': 'text-xs text-zinc-400 uppercase font-bold tracking-wide'}}) }}
                    {{ form_widget(submissionForm.category, {'attr': {'class': 'block mt-2 w-full rounded-md border border-zinc-700 bg-zinc-800 px-4 py-2.5 text-zinc-100 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500'}}) }}
                </div>

                <button type="submit"
                        class="uppercase mt-8 font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-lg py-4 px-12 rounded transition transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-zinc-100">
                    Submit joke
                </button>
            {{ form_end(submissionForm) }}
        </div>
    </div>
{% endblock %}
