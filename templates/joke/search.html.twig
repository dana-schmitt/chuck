{% extends 'base.html.twig' %}

{% block title %}Search jokes{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto min-h-dvh">

        <div class="pb-8 border-b border-zinc-800 text-center">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-8 pb-8">
                Search
            </h1>

            <form method="get" action="{{ path('app_joke_search') }}" class="pt-4">
                <input
                        type="search"
                        name="q"
                        value="{{ query }}"
                        placeholder="Search jokes..."
                        class="block mx-auto w-full sm:w-4/5 md:w-96 rounded-md border border-zinc-700 bg-zinc-800 px-4 py-2.5 text-base text-zinc-100 placeholder-zinc-500 outline-none text-center focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
                        autofocus
                >
                <button type="submit" class="mt-4 uppercase font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-sm py-2.5 px-6 rounded-full transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-white">Search</button>
            </form>
        </div>

        {% if query is empty %}
            <p class="text-center text-zinc-500 italic pt-16">Type something above to search.</p>
        {% elseif results is empty %}
            <p class="text-center text-zinc-500 italic pt-16">No jokes found for "{{ query }}".</p>
        {% else %}
            <ul class="w-3/5 m-auto pt-12 pb-32 space-y-6">
                {% for joke in results %}
                    <li class="border-b border-zinc-800 pb-4">
                        <p class="text-lg text-zinc-300 font-light text-left">
                            {{ joke.joke }}
                            {% for jokeCategory in joke.categories %}
                                <span class="inline-block uppercase text-xs font-bold text-indigo-400 border border-indigo-800 rounded-full px-2 py-0.5 ml-1">{{ jokeCategory }}</span>
                            {% endfor %}
                        </p>
                        <a href="{{ path('app_joke_show', { id: joke.id }) }}" class="text-indigo-400 underline text-sm">View joke &rarr;</a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}
