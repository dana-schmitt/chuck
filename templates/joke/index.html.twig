{% extends 'base.html.twig' %}

{% block body %}

    <div class="w-4/5 m-auto text-center min-h-dvh">

        <div class="pb-8 border-b border-zinc-800">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-8 pb-8">
               Chuck Norris
            </h1>
            <span class="font-light text-zinc-400 italic">
                Jokes Hub
                {% if app.user %}
                    for  {{ app.user.displayName }}
                {% endif %}
            </span>
        </div>

        {% if app.user and availableCategories is defined %}
            <div class="text-center pt-6">
                <a href="{{ path('app_joke') }}" class="inline-block uppercase text-xs font-bold {{ category is null ? 'text-zinc-100' : 'text-zinc-500' }} border border-zinc-700 rounded-full px-3 py-1 m-1 hover:bg-zinc-800">All</a>
                {% for availableCategory in availableCategories %}
                    <a href="{{ path('app_joke', { category: availableCategory }) }}" class="inline-block uppercase text-xs font-bold {{ category == availableCategory ? 'text-zinc-100' : 'text-zinc-500' }} border border-zinc-700 rounded-full px-3 py-1 m-1 hover:bg-zinc-800">{{ availableCategory }}</a>
                {% endfor %}
            </div>
        {% endif %}

        <section class="hero container  mx-auto pt-12 flex">
            <img src="{{ asset('images/chuck.png') }}" class="mx-auto h-64">
        </section>
    {% if app.user %}
        {% if joke %}
            <div id="joke-container" class="w-3/5 m-auto pt-12 text-center">
                <p class="text-xl text-zinc-200 font-light">{{ joke.joke }}</p>

                {% if joke.categories is not empty %}
                    <div class="pt-4">
                        {% for jokeCategory in joke.categories %}
                            <a href="{{ path('app_joke', { category: jokeCategory }) }}" class="inline-block uppercase text-xs font-bold text-indigo-400 border border-indigo-800 rounded-full px-3 py-1 mx-1 hover:bg-indigo-950/50">{{ jokeCategory }}</a>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if joke.id %}
                    <button
                            type="button"
                            data-controller="like"
                            data-like-url-value="{{ path('app_joke_like', { id: joke.id }) }}"
                            data-like-token-value="{{ csrf_token('like' ~ joke.id) }}"
                            data-like-liked-value="{{ liked ? 'true' : 'false' }}"
                            data-action="like#toggle"
                            aria-pressed="{{ liked ? 'true' : 'false' }}"
                            class="mt-6 inline-flex items-center gap-2 text-sm font-bold uppercase {{ liked ? 'text-red-500' : 'text-zinc-500' }} hover:text-red-400 transition transition-all focus:outline-none">
                        <svg class="h-8 w-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                        </svg>
                        <span>Like</span>
                        <span data-like-target="count">{{ likeCount }}</span>
                    </button>

                    <button
                            type="button"
                            data-controller="share"
                            data-share-url-value="{{ url('app_joke_show', { id: joke.id }) }}"
                            data-action="share#share"
                            class="mt-6 ml-6 inline-flex items-center gap-2 text-sm font-bold uppercase text-zinc-500 hover:text-indigo-400 transition transition-all focus:outline-none">
                        <svg class="h-8 w-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L7.04 9.81C6.5 9.31 5.79 9 5 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/>
                        </svg>
                        <span data-share-target="label">Share</span>
                    </button>

                    {% if comments is defined %}
                        <div
                                data-controller="explain"
                                data-explain-url-value="{{ path('app_joke_explain', { id: joke.id }) }}"
                                data-explain-token-value="{{ csrf_token('explain' ~ joke.id) }}"
                                class="mt-8 pt-8 border-t border-zinc-800">
                            <div class="flex items-center justify-center gap-3">
                                <button
                                        type="button"
                                        data-explain-target="explainButton"
                                        data-action="explain#explain"
                                        class="inline-flex items-center gap-2 text-sm font-bold uppercase text-zinc-500 hover:text-indigo-400 transition transition-all focus:outline-none disabled:opacity-50">
                                    <svg class="h-6 w-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M11 18h2v-2h-2v2zm1-16C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-2.21 0-4 1.79-4 4h2c0-1.1.9-2 2-2s2 .9 2 2c0 2-3 1.75-3 5h2c0-2.25 3-2.5 3-5 0-2.21-1.79-4-4-4z"/>
                                    </svg>
                                    <span>Explain this joke</span>
                                </button>

                                <div class="inline-flex text-xs font-bold uppercase">
                                    <button type="button" data-explain-target="localeButton" data-locale="en" data-action="explain#setLocale" class="border rounded-l-full px-3 py-1">EN</button>
                                    <button type="button" data-explain-target="localeButton" data-locale="de" data-action="explain#setLocale" class="border-t border-b border-r rounded-r-full px-3 py-1">DE</button>
                                </div>
                            </div>

                            <p data-explain-target="result" class="hidden mt-4 text-sm text-zinc-300 font-light max-w-xl mx-auto"></p>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        {% else %}
            <div class="w-3/5 m-auto pt-12 text-center">
                <p class="text-xl text-zinc-500 font-light italic">Chuck Norris is too busy to tell a joke right now.</p>
            </div>
        {% endif %}

        {% if comments is defined %}
            <div class="w-3/5 m-auto pt-12 pb-12 text-left">
                <h2 class="uppercase font-bold text-zinc-100 text-sm tracking-wide mb-4">Comments</h2>

                {% if comments is empty %}
                    <p class="text-zinc-500 italic text-sm">No comments yet. Be the first to say something.</p>
                {% else %}
                    <ul class="space-y-4 mb-8">
                        {% for comment in comments %}
                            <li class="border-b border-zinc-800 pb-4">
                                <p class="text-sm text-zinc-300">{{ comment.body }}</p>
                                <p class="text-xs text-zinc-500 mt-1">
                                    {{ comment.author.displayName }} &middot; {{ comment.createdAt|date('Y-m-d H:i') }}
                                </p>

                                <div
                                        data-controller="reaction"
                                        data-reaction-url-value="{{ path('app_comment_react', { jokeId: joke.id, id: comment.id }) }}"
                                        data-reaction-token-value="{{ csrf_token('react-comment' ~ comment.id) }}"
                                        class="mt-2 flex gap-2">
                                    {% for emoji in reactionEmojis %}
                                        <button
                                                type="button"
                                                data-reaction-target="button"
                                                data-emoji="{{ emoji }}"
                                                data-action="reaction#toggle"
                                                class="px-2 py-1 rounded-full border text-sm {{ emoji in (userReactedEmojis[comment.id] ?? []) ? 'border-indigo-500 bg-indigo-950/50' : 'border-zinc-700' }}">
                                            {{ emoji }} <span data-reaction-count>{{ (reactionCounts[comment.id] ?? {})[emoji] ?? 0 }}</span>
                                        </button>
                                    {% endfor %}
                                </div>

                                {% if app.user and (app.user == comment.author or is_granted('ROLE_ADMIN')) %}
                                    <form method="post" action="{{ path('app_comment_delete', { jokeId: joke.id, id: comment.id }) }}" class="mt-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-comment' ~ comment.id) }}">
                                        <button type="submit" class="text-xs text-zinc-500 hover:text-red-400 underline">Delete</button>
                                    </form>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                {{ form_start(commentForm, { action: path('app_comment_create', { id: joke.id }), attr: { class: 'space-y-2' } }) }}
                    {{ form_row(commentForm.body, { attr: { class: 'w-full rounded-md border border-zinc-700 bg-zinc-800 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500' } }) }}
                    <button type="submit" class="uppercase text-xs font-bold text-white bg-indigo-500 rounded-full px-4 py-2 hover:bg-indigo-600">Post comment</button>
                {{ form_end(commentForm) }}
            </div>
        {% endif %}

        <div class="text-center pt-12">
            <a href="{{ path('app_joke', category ? { category: category } : {}) }}" class="uppercase font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-sm py-2.5 px-6 rounded-full transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-white">CHUCK ME</a>
        </div>

        <div class="pb-24"></div>
    {% endif %}
    </div>
{% endblock %}
