{% extends 'base.html.twig' %}

{% block body %}

    <div class="w-4/5 m-auto text-center min-h-full h-screen">

        <div class="pb-8 border-b border-gray-200">
            <h1 class="uppercase font-bold text-5xl text-gray-800 pt-36 pb-8">
               Chuck Norris
            </h1>
            <span class="font-light text-gray-500 italic">
                Jokes Hub
                {% if app.user %}
                    for  {{app.user.email}}
                {% endif %}
            </span>
        </div>

        <section class="hero container  mx-auto pt-12 flex">
            <img src="{{ asset('images/chuck.png') }}" class="mx-auto h-64">
        </section>
    {% if app.user %}
        {% if joke %}
            <div id="joke-container" class="w-3/5 m-auto pt-12 text-center">
                <p class="text-xl text-gray-700 font-light">{{ joke.joke }}</p>

                {% if joke.categories is not empty %}
                    <div class="pt-4">
                        {% for jokeCategory in joke.categories %}
                            <a href="{{ path('app_joke', { category: jokeCategory }) }}" class="inline-block uppercase text-xs font-bold text-indigo-500 border border-indigo-300 rounded-full px-3 py-1 mx-1 hover:bg-indigo-50">{{ jokeCategory }}</a>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if joke.id %}
                    <button
                            type="button"
                            data-controller="like"
                            data-like-url-value="{{ path('app_joke_like', { id: joke.id }) }}"
                            data-like-token-value="{{ csrf_token('like' ~ joke.id) }}"
                            data-like-liked-value="{{ liked ? 'true' : 'false' }}"
                            data-action="like#toggle"
                            aria-pressed="{{ liked ? 'true' : 'false' }}"
                            class="mt-6 inline-flex items-center gap-2 text-sm font-bold uppercase {{ liked ? 'text-red-500' : 'text-gray-300' }} hover:text-red-400 transition transition-all focus:outline-none">
                        <svg class="h-8 w-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                        </svg>
                        <span>Like</span>
                        <span data-like-target="count">{{ likeCount }}</span>
                    </button>

                    <button
                            type="button"
                            data-controller="share"
                            data-share-url-value="{{ url('app_joke_show', { id: joke.id }) }}"
                            data-action="share#share"
                            class="mt-6 ml-6 inline-flex items-center gap-2 text-sm font-bold uppercase text-gray-300 hover:text-indigo-400 transition transition-all focus:outline-none">
                        <svg class="h-8 w-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L7.04 9.81C6.5 9.31 5.79 9 5 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/>
                        </svg>
                        <span data-share-target="label">Share</span>
                    </button>
                {% endif %}
            </div>
        {% else %}
            <div class="w-3/5 m-auto pt-12 text-center">
                <p class="text-xl text-gray-500 font-light italic">Chuck Norris is too busy to tell a joke right now.</p>
            </div>
        {% endif %}

        <div class="text-center pt-12">
            <a href="{{ path('app_joke', category ? { category: category } : {}) }}" class="uppercase font-bold border border-gray-300 bg-yellow-400 text-gray-800 text-lg py-4 px-12 rounded transition transition-all shadow-xl hover:border hover:border-gray-300 hover:bg-indigo-400 hover:text-white">CHUCK ME</a>
        </div>

        {% if availableCategories is defined %}
            <div class="text-center pt-8 pb-24">
                <a href="{{ path('app_joke') }}" class="inline-block uppercase text-xs font-bold {{ category is null ? 'text-gray-800' : 'text-gray-400' }} border border-gray-300 rounded-full px-3 py-1 m-1 hover:bg-gray-100">All</a>
                {% for availableCategory in availableCategories %}
                    <a href="{{ path('app_joke', { category: availableCategory }) }}" class="inline-block uppercase text-xs font-bold {{ category == availableCategory ? 'text-gray-800' : 'text-gray-400' }} border border-gray-300 rounded-full px-3 py-1 m-1 hover:bg-gray-100">{{ availableCategory }}</a>
                {% endfor %}
            </div>
        {% else %}
            <div class="pb-24"></div>
        {% endif %}
    {% endif %}
    </div>
{% endblock %}
