{% extends 'base.html.twig' %}

{% block title %}Admin{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto min-h-dvh">

        <div class="pb-8 border-b border-zinc-800 text-center">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-8 pb-8">
                Admin
            </h1>
        </div>

        <div class="w-3/5 m-auto pt-12 flex justify-around text-center">
            <div>
                <p class="text-4xl font-bold text-zinc-100">{{ userCount }}</p>
                <p class="uppercase text-sm text-zinc-400">Users</p>
            </div>
            <div>
                <p class="text-4xl font-bold text-zinc-100">{{ jokeCount }}</p>
                <p class="uppercase text-sm text-zinc-400">Jokes</p>
            </div>
            <div>
                <p class="text-4xl font-bold text-zinc-100">{{ likeCount }}</p>
                <p class="uppercase text-sm text-zinc-400">Likes</p>
            </div>
            <div>
                <p class="text-4xl font-bold {{ pendingCount > 0 ? 'text-red-400' : 'text-zinc-100' }}">{{ pendingCount }}</p>
                <p class="uppercase text-sm text-zinc-400">Pending</p>
            </div>
        </div>

        <div class="text-center pt-16 pb-24 space-x-4">
            <a href="{{ path('app_admin_users') }}" class="uppercase font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-sm py-2.5 px-6 rounded-full transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-white">Manage users</a>
            <a href="{{ path('app_admin_jokes') }}" class="uppercase font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-sm py-2.5 px-6 rounded-full transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-white">Manage jokes</a>
        </div>
    </div>
{% endblock %}
