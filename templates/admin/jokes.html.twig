{% extends 'base.html.twig' %}

{% block title %}Admin - Jokes{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto min-h-dvh">

        <div class="pb-8 border-b border-zinc-800 text-center">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-8 pb-8">
                Jokes
            </h1>
            <a href="{{ path('app_admin_dashboard') }}" class="text-indigo-400 underline text-sm">&larr; Back to admin</a>
        </div>

        <ul class="w-3/5 m-auto pt-12 pb-32 space-y-6">
            {% for joke in jokes %}
                <li class="flex items-start justify-between gap-4 border-b border-zinc-800 pb-4">
                    <p class="text-lg text-zinc-300 font-light text-left">
                        {% if not joke.approved %}
                            <span class="inline-block uppercase text-xs font-bold text-yellow-300 bg-yellow-900/40 rounded-full px-2 py-0.5 mr-1">Pending</span>
                        {% endif %}
                        {{ joke.joke }}
                        {% for jokeCategory in joke.categories %}
                            <span class="inline-block uppercase text-xs font-bold text-indigo-400 border border-indigo-800 rounded-full px-2 py-0.5 ml-1">{{ jokeCategory }}</span>
                        {% endfor %}
                        <span class="block text-xs text-zinc-500 pt-1">
                            {{ likeCounts[joke.id] }} like{{ likeCounts[joke.id] == 1 ? '' : 's' }}
                            {% if joke.submittedBy %}
                                &middot; submitted by {{ joke.submittedBy.email }}
                            {% endif %}
                        </span>

                        {% if not joke.approved %}
                            <span class="block text-sm pt-3">
                                {% set moderation = moderationResults[joke.id] ?? null %}
                                {% if moderation is null %}
                                    <span class="text-zinc-500 italic">No AI analysis available.</span>
                                {% else %}
                                    {% set recommendationColor = {
                                        approve: 'text-green-300 bg-green-900/40 border-green-800',
                                        reject: 'text-red-300 bg-red-900/40 border-red-800',
                                        unsure: 'text-yellow-300 bg-yellow-900/40 border-yellow-800',
                                    } %}
                                    <span class="inline-block uppercase text-xs font-bold border rounded-full px-2 py-0.5 {{ recommendationColor[moderation.recommendation.value] }}">
                                        AI: {{ moderation.recommendation.value }} ({{ (moderation.confidence * 100)|round }}%)
                                    </span>
                                    {% for flag in moderation.flags %}
                                        <span class="inline-block uppercase text-xs font-bold text-zinc-400 border border-zinc-700 rounded-full px-2 py-0.5 ml-1">{{ flag.value|replace({'_': ' '}) }}</span>
                                    {% endfor %}
                                    {% if moderation.reasons is not empty %}
                                        <ul class="text-xs text-zinc-500 list-disc list-inside pt-1">
                                            {% for reason in moderation.reasons %}
                                                <li>{{ reason }}</li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                    {% if moderation.duplicateOf %}
                                        <a href="{{ path('app_joke_show', { id: moderation.duplicateOf.id }) }}" class="block text-xs text-indigo-400 underline pt-1">
                                            Possible duplicate of joke #{{ moderation.duplicateOf.id }}
                                        </a>
                                    {% endif %}
                                {% endif %}
                            </span>
                        {% endif %}
                    </p>
                    <div class="shrink-0 flex gap-3">
                        {% if not joke.approved %}
                            <form method="post" action="{{ path('app_admin_joke_approve', { id: joke.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve-joke' ~ joke.id) }}">
                                <button type="submit" class="uppercase text-xs font-bold text-green-400 underline">Approve</button>
                            </form>
                        {% endif %}
                        <form
                                method="post"
                                action="{{ path('app_admin_joke_delete', { id: joke.id }) }}"
                                data-controller="confirm"
                                data-confirm-message-value="Delete this joke?"
                                data-action="submit->confirm#confirm">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-joke' ~ joke.id) }}">
                            <button type="submit" class="uppercase text-xs font-bold text-red-400 underline">Delete</button>
                        </form>
                    </div>
                </li>
            {% endfor %}
        </ul>
    </div>
{% endblock %}
