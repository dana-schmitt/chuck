{% extends 'base.html.twig' %}

{% block title %}Admin - Jokes{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto min-h-full h-screen">

        <div class="pb-8 border-b border-gray-200 text-center">
            <h1 class="uppercase font-bold text-5xl text-gray-800 pt-36 pb-8">
                Jokes
            </h1>
            <a href="{{ path('app_admin_dashboard') }}" class="text-indigo-500 underline text-sm">&larr; Back to admin</a>
        </div>

        <ul class="w-3/5 m-auto pt-12 pb-32 space-y-6">
            {% for joke in jokes %}
                <li class="flex items-start justify-between gap-4 border-b border-gray-100 pb-4">
                    <p class="text-lg text-gray-700 font-light text-left">
                        {{ joke.joke }}
                        {% for jokeCategory in joke.categories %}
                            <span class="inline-block uppercase text-xs font-bold text-indigo-500 border border-indigo-300 rounded-full px-2 py-0.5 ml-1">{{ jokeCategory }}</span>
                        {% endfor %}
                        <span class="block text-xs text-gray-400 pt-1">{{ likeCounts[joke.id] }} like{{ likeCounts[joke.id] == 1 ? '' : 's' }}</span>
                    </p>
                    <form method="post" action="{{ path('app_admin_joke_delete', { id: joke.id }) }}" onsubmit="return confirm('Delete this joke?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-joke' ~ joke.id) }}">
                        <button type="submit" class="shrink-0 uppercase text-xs font-bold text-red-500 underline">Delete</button>
                    </form>
                </li>
            {% endfor %}
        </ul>
    </div>
{% endblock %}
