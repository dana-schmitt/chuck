{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto text-center">
        <div class="py-12">
            <h1 class="uppercase font-bold text-5xl text-gray-800 pt-48 pb-8">
                Chuckify Yourself
            </h1>

            {% set field_class = 'bg-transparent block mt-10 mx-auto border-b-2 sm:w-4/5 md:w-2/5 h-20 text-lg outline-none' %}
            {{ form_start(registrationForm) }}
                {{ form_row(registrationForm.email, {'attr': {'class': field_class}}) }}
                {{ form_row(registrationForm.plainPassword, {'attr': {'class': field_class}}) }}


            <button
                type="submit"
               class="uppercase mt-16 font-bold border border-gray-300 bg-yellow-400 text-gray-800 text-lg py-4 px-12 rounded transition transition-all shadow-xl hover:border hover:border-gray-300 hover:bg-indigo-400 hover:text-zinc-100">
                CHUCK ME
            </button>

            {{ form_end(registrationForm) }}

        </div>
            <a href="/login" class="underline text-gray-800  py-4 px-12 transition transition-all hover:text-zinc-500">already have an account?  → Chuck in</a>
    </div>
{% endblock %}
