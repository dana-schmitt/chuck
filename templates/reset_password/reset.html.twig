{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto text-center">
        <div class="py-12">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-12 pb-8">
                Reset your password
            </h1>

            {% set field_class = 'block mt-4 mx-auto w-full sm:w-96 rounded-md border border-zinc-700 bg-zinc-800 px-4 py-2.5 text-base text-zinc-100 placeholder-zinc-500 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500' %}
            {{ form_start(resetForm) }}
                {{ form_row(resetForm.plainPassword.first, {'attr': {'class': field_class, 'placeholder': 'New password'}, 'label': false}) }}
                {{ form_row(resetForm.plainPassword.second, {'attr': {'class': field_class, 'placeholder': 'Repeat password'}, 'label': false}) }}

                <button type="submit"
                        class="uppercase mt-10 font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-lg py-4 px-12 rounded transition transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-zinc-100">
                    Reset password
                </button>
            {{ form_end(resetForm) }}
        </div>
    </div>
{% endblock %}
