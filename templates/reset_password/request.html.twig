{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <div class="w-4/5 m-auto text-center">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="text-red-400 mt-6">{{ flash_error }}</div>
        {% endfor %}

        <div class="py-12">
            <h1 class="uppercase font-bold text-5xl text-zinc-100 pt-12 pb-8">
                Forgot your password?
            </h1>
            <span class="font-light text-zinc-400 italic">
                Enter your email and we'll send you a reset link.
            </span>

            {% set field_class = 'block mt-4 mx-auto w-full sm:w-96 rounded-md border border-zinc-700 bg-zinc-800 px-4 py-2.5 text-base text-zinc-100 placeholder-zinc-500 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500' %}
            {{ form_start(requestForm) }}
                {{ form_row(requestForm.email, {'attr': {'class': field_class, 'placeholder': 'Email'}, 'label': false}) }}

                <button type="submit"
                        class="uppercase mt-10 font-bold border border-zinc-700 bg-yellow-400 text-zinc-900 text-sm py-2.5 px-6 rounded-full transition-all shadow-xl hover:border-zinc-600 hover:bg-indigo-400 hover:text-white">
                    Send reset link
                </button>
            {{ form_end(requestForm) }}
        </div>
        <a href="{{ path('app_login') }}" class="underline text-zinc-300 py-4 px-12 transition transition-all hover:text-zinc-100">Back to login</a>
    </div>
{% endblock %}
