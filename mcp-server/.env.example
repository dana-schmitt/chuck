# Copy to .env for local runs, or set these as real environment variables in
# your MCP client config. Never commit a file with real values filled in.

# Base URL of the Chuckify app's JSON API.
API_BASE_URL=http://127.0.0.1:8000

# Created with: php bin/console app:api-token:create mcp-server
# (run from the Chuckify app directory) - shown once at creation time.
API_TOKEN=

REQUEST_TIMEOUT_SECONDS=10
