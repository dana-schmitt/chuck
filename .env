# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=2ed858d8b5d2eafec49a0de37e377225
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
DATABASE_URL="mysql://root:chuckme@127.0.0.1:3306/joke?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Real DSN (resend+api://RESEND_API_KEY@default) is provided via env var / secrets vault in prod.
# See README > Production > Secrets.
MAILER_DSN=null://null
###< symfony/mailer ###

###> sentry/sentry-symfony ###
# Left empty here on purpose: the SDK sends nothing when SENTRY_DSN is unset, so dev/test are
# no-ops by default. Real DSN is provided via env var / secrets vault in prod.
# See README > Production > Secrets.
SENTRY_DSN=
###< sentry/sentry-symfony ###

###> ai-service ###
# "http" talks to the ai-service container (see compose.yaml); "null" disables AI features
# entirely without needing that container running at all - see App\Ai\AiProviderFactory.
AI_PROVIDER=http
# Host-exposed port from compose.override.yaml, since PHP itself runs outside Docker in dev
# (see README > Development). In compose.prod.yaml this instead points at the internal
# Docker network name, e.g. http://ai-service:8000.
AI_SERVICE_BASE_URL=http://127.0.0.1:8001
# Must match ai-service's own SHARED_SECRET (compose.yaml). Dev-only placeholder - real value
# is provided via env var / secrets vault in prod. See README > Production > Secrets.
AI_SERVICE_SHARED_SECRET=dev-only-shared-secret-change-me
###< ai-service ###

###> symfony/messenger ###
# Backed by the messenger_messages table in the app's own database - see
# config/packages/messenger.yaml. auto_setup=0 since the table comes from a real migration
# (bin/console doctrine:migrations:diff), not created ad hoc at runtime.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> ai search ###
# Optional LLM reranking of the top-20 cosine-similarity search results down to top-5.
# Off by default: it's an extra /complete call (cost + latency) on every search, and cosine
# similarity alone already gives reasonable results.
AI_SEARCH_RERANK=false
# Recorded alongside each stored embedding (App\Entity\JokeEmbedding::$model) - informational
# only, PHP never calls OpenAI directly. Keep in sync with ai-service's own EMBEDDING_MODEL.
EMBEDDING_MODEL=text-embedding-3-small
###< ai search ###
